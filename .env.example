# Copy to .env (DO NOT commit) and fill in real values before docker-compose up.
#
# Generate fresh secrets with:
#   node -e "const c=require('crypto');const s=c.randomBytes(32).toString('hex');const pin='YOUR_PIN_HERE';console.log('AUTH_SECRET='+s);console.log('PIN_HASH='+c.createHmac('sha256',s).update(pin).digest('hex'));"

# Sub-path the SPA is served under (e.g. "/dy/" behind Nginx, "/" if dedicated host)
DOUYIN_BASE=/

# Local-only port Nginx proxies into. Container always listens on 3000 inside.
HOST_PORT=3000

# === Auth (required in production) ===
# AUTH_SECRET: random 32+ bytes hex, used to HMAC PIN and session cookies.
# Rotating this invalidates ALL existing sessions.
AUTH_SECRET=

# PIN_HASH: hex(HMAC-SHA256(AUTH_SECRET, your_pin)). The plain PIN is NEVER stored.
PIN_HASH=

# Session lifetime (cookie max-age) in milliseconds. Default = 30 days.
# Sliding renewal automatically extends sessions used within the last day,
# so daily users effectively never get logged out.
SESSION_TTL_MS=2592000000

# === OSS Mirror (optional, recommended for low-bandwidth servers) ===
# When configured, /api/parse will ask the OSS provider to "cloud-fetch" each
# media object (video / cover / images / music) directly from Douyin CDN
# into your bucket. The browser then downloads from the bucket's CDN, so
# our origin server transfers ZERO bytes. Without these vars, the app falls
# back to streaming through /api/download (limited by your origin bandwidth).
#
# Supported providers: qiniu | tencent-cos | aliyun-oss | s3
# (only `qiniu` is fully implemented at the moment).
OSS_PROVIDER=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=

# Provider-specific zone code:
#   qiniu: z0 (huadong) | z1 (huabei) | z2 (huanan) | na0 | as0
#   tencent-cos: ap-shanghai etc.
#   aliyun-oss: oss-cn-hangzhou etc.
OSS_REGION=

# Public CDN host bound to the bucket (no trailing slash).
# Example: https://img.cdn.example.com
OSS_PUBLIC_HOST=

# Signed URL TTL in MINUTES. Should match (or be ≤) your bucket lifecycle rule
# that auto-deletes objects. Default 30 (== "auto-delete after 30 minutes").
# Legacy OSS_OBJECT_TTL_HOURS is still honored for older deployments.
OSS_OBJECT_TTL_MINUTES=30

# Auto-warmup switch. Default OFF. When OFF, /api/parse will NOT push anything
# to OSS even if the credentials above are set — the only way to upload is
# the manual "Test mirror" button (POST /api/mirror/test). This is the safe
# default because some providers (e.g. Qiniu fetch API) cannot forward a
# Referer header, which can cause Douyin CDN to reject the pull. Verify with
# the test button first, then set this to 1 to enable for every parse.
#
# Accepted truthy values: 1 / true / yes
OSS_AUTO_MIRROR=0
